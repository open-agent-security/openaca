<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ advisory.id }} — OpenACA</title>
  <link rel="canonical" href="https://openaca.dev/overlays/{{ advisory.id }}.html">
  <link rel="stylesheet" href="../style.css">
</head>
<body>
  <header>
    <p><a href="../">← OpenACA</a></p>
    <h1>{{ advisory.id }}</h1>
    <p class="tagline">OpenACA agent-context overlay</p>
  </header>

  <dl class="advisory-meta">
    <dt>Modified:</dt><dd>{{ advisory.modified }}</dd>
  </dl>

  {% if advisory.aliases %}
  <section>
    <h2>Aliases</h2>
    <ul>
      {% for alias in advisory.aliases %}
      <li><code>{{ alias }}</code></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if advisory.affected %}
  <section>
    <h2>Affected packages</h2>
    <table>
      <thead><tr><th>Ecosystem</th><th>Name</th><th>Fixed in</th></tr></thead>
      <tbody>
        {% for entry in advisory.affected %}
        <tr>
          <td>{{ entry.package.ecosystem }}</td>
          <td><code>{{ entry.package.name }}</code></td>
          <td>
            {%- for r in entry.ranges or [] -%}
              {%- for ev in r.events or [] -%}
                {%- if ev.fixed -%}<code>{{ ev.fixed }}</code>{%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  {% endif %}

  {% if advisory.severity %}
  <section>
    <h2>Severity</h2>
    <ul>
      {% for sev in advisory.severity %}
      <li>{{ sev.type }} — <code>{{ sev.score }}</code></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if advisory.details %}
  <section>
    <h2>Details</h2>
    <p>{{ advisory.details }}</p>
  </section>
  {% endif %}

  {% set openaca = (advisory.database_specific or {}).get('openaca') or {} %}
  {% if openaca %}
  <section>
    <h2>Agent context</h2>
    {% if openaca.threat_kind %}<p>Threat kind: <code>{{ openaca.threat_kind }}</code></p>{% endif %}
    {% set taxonomies = openaca.taxonomies or {} %}
    {% if taxonomies %}
      {% if taxonomies.owasp_agentic_top10 %}
      <p>OWASP Agentic Top 10: {% for c in taxonomies.owasp_agentic_top10 %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</p>
      {% endif %}
      {% if taxonomies.owasp_mcp_top10 %}
      <p>OWASP MCP Top 10: {% for c in taxonomies.owasp_mcp_top10 %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</p>
      {% endif %}
      {% if taxonomies.owasp_agentic_skills_top10 %}
      <p>OWASP Agentic Skills Top 10: {% for c in taxonomies.owasp_agentic_skills_top10 %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</p>
      {% endif %}
      {% if taxonomies.owasp_llm_top10 %}
      <p>OWASP LLM Top 10: {% for c in taxonomies.owasp_llm_top10 %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</p>
      {% endif %}
      {% if taxonomies.mitre_atlas %}
      <p>MITRE ATLAS: {% for c in taxonomies.mitre_atlas %}<code>{{ c }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</p>
      {% endif %}
    {% endif %}
    {% if openaca.evidence_level %}<p>Evidence: <code>{{ openaca.evidence_level }}</code></p>{% endif %}
  </section>
  {% endif %}

  {% if advisory.references %}
  <section>
    <h2>References</h2>
    <ul>
      {% for ref in advisory.references %}
      <li>{{ ref.type }}: <a href="{{ ref.url }}">{{ ref.url }}</a></li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <footer>
    <a href="{{ advisory.id }}.json">JSON</a>
    <a href="../">Back to index</a>
  </footer>
</body>
</html>
