{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asve.dev/schema/asve.schema.json",
  "title": "ASVE Overlay",
  "type": "object",
  "required": ["schema_version", "id", "modified", "database_specific"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "id": {"type": "string", "minLength": 1},
    "type": {"type": "string", "enum": ["vulnerability", "exposure", "config"]},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string", "minLength": 1, "maxLength": 200},
    "details": {"type": "string", "minLength": 1},
    "published": {"type": "string", "format": "date-time"},
    "modified": {"type": "string", "format": "date-time"},
    "withdrawn": {"type": "string", "format": "date-time"},
    "severity": {"type": "array", "items": {"$ref": "#/$defs/severity"}},
    "references": {"type": "array", "items": {"$ref": "#/$defs/reference"}, "minItems": 1},
    "affected": {"type": "array", "items": {"$ref": "#/$defs/affected"}},
    "database_specific": {"$ref": "#/$defs/database_specific"}
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "exposure"}}, "required": ["type"]},
      "then": {"not": {"description": "exposure records are reserved; rejected in V0"}}
    },
    {
      "if": {"properties": {"type": {"const": "config"}}, "required": ["type"]},
      "then": {"not": {"description": "config records are reserved; rejected in V0"}}
    }
  ],
  "$defs": {
    "severity": {
      "type": "object",
      "required": ["type", "score"],
      "properties": {
        "type": {"type": "string", "enum": ["CVSS_V3", "CVSS_V4"]},
        "score": {"type": "string", "pattern": "^CVSS:(3\\.[01]|4\\.0)/"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"type": {"const": "CVSS_V3"}},
            "required": ["type"]
          },
          "then": {
            "properties": {"score": {"pattern": "^CVSS:3\\.[01]/"}}
          }
        },
        {
          "if": {
            "properties": {"type": {"const": "CVSS_V4"}},
            "required": ["type"]
          },
          "then": {
            "properties": {"score": {"pattern": "^CVSS:4\\.0/"}}
          }
        }
      ]
    },
    "reference": {
      "type": "object",
      "required": ["type", "url"],
      "properties": {
        "type": {"type": "string", "enum": ["ADVISORY", "ARTICLE", "FIX", "PACKAGE", "REPORT", "WEB"]},
        "url": {"type": "string", "format": "uri"}
      }
    },
    "affected": {
      "type": "object",
      "required": ["package"],
      "properties": {
        "package": {
          "type": "object",
          "required": ["ecosystem", "name"],
          "properties": {
            "ecosystem": {"type": "string"},
            "name": {"type": "string"},
            "purl": {"type": "string"}
          }
        },
        "ranges": {"type": "array"},
        "versions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "database_specific": {
      "type": "object",
      "properties": {
        "asve": {"$ref": "#/$defs/asve_extension"}
      }
    },
    "asve_extension": {
      "type": "object",
      "required": ["component_type"],
      "properties": {
        "component_type": {"type": "string"},
        "component_identity": {"type": "string"},
        "surfaces": {"type": "array", "items": {"type": "string"}},
        "agent_impact": {
          "type": "object",
          "additionalProperties": {"type": "boolean"}
        },
        "threat_kind": {"type": "string"},
        "taxonomies": {"$ref": "#/$defs/asve_taxonomies"},
        "evidence_level": {
          "type": "string",
          "enum": ["confirmed", "likely", "research", "disputed", "withdrawn"]
        }
      }
    },
    "asve_taxonomies": {
      "type": "object",
      "properties": {
        "owasp_agentic_top10": {
          "type": "array",
          "items": {"type": "string", "pattern": "^asi(0[1-9]|10)$"}
        },
        "owasp_mcp_top10": {
          "type": "array",
          "items": {"type": "string", "pattern": "^mcp(0[1-9]|10):[0-9]{4}$"}
        },
        "owasp_agentic_skills_top10": {
          "type": "array",
          "items": {"type": "string", "pattern": "^ast(0[1-9]|10):[0-9]{4}$"}
        },
        "owasp_llm_top10": {
          "type": "array",
          "items": {"type": "string", "pattern": "^llm(0[1-9]|10):[0-9]{4}$"}
        },
        "mitre_atlas": {
          "type": "array",
          "items": {"type": "string", "pattern": "^AML\\.T[0-9]{4}(\\.[0-9]{3})?$"}
        },
        "supplemental_taxonomies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      },
      "additionalProperties": false
    }
  }
}
